<div class="content-box">
	<h2>Create a new card</h2>
	<hr/>
	<form id="card-editor" action="/api/cards/create" method="POST">

		<div id="card-editor-body">

			<div class="deck-name">
				<label for="question">Question:</label>
				<input name="question" type="text" placeholder="What is the answer?" required/>
			</div>
			<img class="deck-thumb" src="/img/favicon.svg"/>
			<div class="deck-name">
				<label for="answer">Answer:</label>
				<input name="answer" type="text" placeholder="42" required/>
			</div>
			<div>
				<label for="typeins">Type-ins:</label>
				<textarea name="typeins" placeholder="Enter one or more type-ins separated by a line break." rows="4"></textarea>
			</div>
		</div>
		<input class="button-highlighted" type="submit" value="Create"/>
	</form>
</div>
