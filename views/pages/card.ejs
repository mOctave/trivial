<!DOCTYPE html>
<html>
	<head>
		<%- include("../partials/head"); %>
	</head>
	<body>
		<%- include("../partials/navbar"); %>
		<div class="left-bar">
			<div class="content-box">
				<div class="question"><%- cards[0].question %></div>
				<% if(cards[0].image) { %>
					<img class="pfp" src="<%- cards[0].image %>"/>
				<% } %>
				<hr/>
				<div class="answer"><%- cards[0].answer %></div>
				<div class="deck-creator">Created by <%- cards[0].creator %></div>
				<div class="fine-print"><%- cards[0]._id %></div>
			</div>
		</div>
		<div class="main-container">
			<div class="content-box">
				<p>This card was created <%- cards[0].dateCreated %> by <%- cards[0].creator %> and was last modified <%- cards[0].dateModified %>. It has been correctly answered <%- cards[0].correct %> times out of the <%- cards[0].presentations %> times it has been shown.</p>
			</div>
			<div class="content-box">
				<h2>Decks with this card</h2>
				<%- include("../partials/deckbox"); %>
			</div>
		</div>
		<div class="right-bar">
			<%- include("../partials/leaderboard"); %>
			<%- include("../partials/contribute"); %>
		</div>
	</body>
</html>
