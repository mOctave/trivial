<!DOCTYPE html>
<html>
	<head>
		<%- include("../partials/head"); %>
		<script src="/scripts/utils/timestamp.js"></script>
	</head>
	<body>
		<%- include("../partials/navbar"); %>
		<div class="page-wrapper">
			<div class="left-bar">
				<div class="content-box">
					<div class="question"><%- cards[0].question %></div>
					<% if(cards[0].image) { %>
						<img class="card-thumb" src="<%- cards[0].image %>"/>
					<% } %>
					<hr/>
					<div class="answer"><%- cards[0].answer %></div>
					<% if(cards[0].typeins.length > 0) { %>
					<div class="type-ins">
						<p>Also accepted:</p>
						<ul>
							<% for (const typein of cards[0].typeins) { %>
								<li><%- typein %></li>
							<% } %>
						</ul>
					</div>
					<% } %>
					<div class="deck-creator">Created by <%- cards[0].creator %></div>
					<div class="fine-print"><%- cards[0]._id %></div>
				</div>
				<div class="left-overflow">
					<%- include("../partials/leaderboard"); %>
				</div>
			</div>
			<div class="main-container">
				<div class="content-box">
					<%- include("../partials/carddesc"); %>
				</div>
				<div class="content-box">
					<h2>Decks with this card</h2>
					<%- include("../partials/deckbox"); %>
				</div>
			</div>
			<div class="right-bar">
				<%- include("../partials/leaderboard"); %>
				<%- include("../partials/contribute"); %>
			</div>
		</div>
		<%- include("../partials/copyright"); %>
	</body>
</html>
