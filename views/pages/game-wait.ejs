<!DOCTYPE html>
<html class="gamewindow">
	<head>
		<%- include("../partials/head"); %>
		<script src="/scripts/utils/timestamp.js"></script>
	</head>
	<body>
		<%- include("../partials/navbar"); %>
		<div class="page-wrapper game-container">
			<div class="left-bar">
				<div id="game-details" class="content-box">
				</div>
				<div id="wait-condition" class="content-box">
				</div>
				<div id="time-indicator"><div id="time-left"></div><div id="time-bar"></div></div>
				<div class="left-overflow">
					<%- include("../partials/playerbar") %>
				</div>
			</div>
			<div class="main-container">
				<button id="start-button" onclick="startGame()" style="display:none;">Start!</button>
			</div>
			<div class="right-bar">
				<%- include("../partials/playerbar") %>
			</div>
		</div>
	<script>
		window.activeUserData = <%- JSON.stringify(activeUser) %>;
	</script>
	<script src="/scripts/utils/timestamp.js"></script>
	<script src="/scripts/fillers/game-wait.js" defer></script>
	</body>
</html>
