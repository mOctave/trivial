<!DOCTYPE html>
<html>
	<head>
		<%- include("../partials/head"); %>
	</head>
	<body>
		<%- include("../partials/navbar"); %>
		<div class="left-bar">
			<div class="content-box">
				<h2><%- decks[0].name %></h2>
				<img class="pfp" src="<%- decks[0].image %>"/>
				<p>Created by <%- decks[0].creator %></p>
				<p><%- decks[0].cards.length %> cards</p>
				<p><%- decks[0].stars %> stars</p>
				<div class="fine-print"><%- decks[0]._id %></div>
			</div>
		</div>
		<div class="main-container">
			<div class="content-box">
				<%- include("../partials/cardbox"); %>
			</div>
		</div>
		<div class="right-bar">
			<%- include("../partials/leaderboard"); %>
			<%- include("../partials/contribute"); %>
		</div>
	</body>
</html>
